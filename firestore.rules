rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── EXAMS ──
    // Siapa saja bisa baca (siswa perlu ambil data ujian saat join)
    // Hanya guru (user terautentikasi) yang bisa menulis
    match /exams/{examCode} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── RESULTS ──
    // Siapa saja bisa membuat hasil baru (siswa submit)
    // Hanya guru yang bisa membaca semua / menghapus
    match /results/{resultId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
      allow update: if false;
    }

    // ── PARTICIPANTS ──
    // Siswa bisa tulis (join/update status), guru bisa baca
    match /participants/{docId} {
      allow read:   if request.auth != null;
      allow write:  if true;
    }

    // ── PERMISSION REQUESTS ──
    // Siswa bisa buat & baca request miliknya, guru bisa baca & update semua
    match /permissionRequests/{docId} {
      allow create: if true;
      allow read:   if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── CONFIG ──
    // Hanya guru yang bisa baca & tulis
    match /config/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
